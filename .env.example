# Convex deployment URL — get this from https://dashboard.convex.dev
# Example: https://happy-dog-123.convex.cloud
VITE_CONVEX_URL=

# Your project ID (visible in the Convex dashboard or use a placeholder for now)
VITE_PROJECT_ID=your_project_id_here

# ── Server-side (Convex Dashboard → Settings → Environment Variables) ──
# The AI Assistant uses a Convex server-side action to call Fireworks AI.
# The API key NEVER reaches the browser. Set it in the Convex dashboard:
#   Variable name:  FIREWORKS_API_KEY
#   Value:          fw_... (from https://app.fireworks.ai/users/api-keys)
